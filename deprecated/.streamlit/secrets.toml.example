# Streamlit Secrets Template
# Copy this file to secrets.toml and fill in your actual values
# 复制此文件为secrets.toml并填入你的实际值

# ⚠️ NEVER commit secrets.toml to GitHub!
# ⚠️ 永远不要将secrets.toml提交到GitHub！
# Add to .gitignore: .streamlit/secrets.toml

[onedrive]
# Azure App Registration Client ID
# From: Azure Portal → App Registrations → Your App → Overview
client_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Azure App Registration Client Secret
# From: Azure Portal → App Registrations → Your App → Certificates & secrets
client_secret = "xxx~xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# OAuth Refresh Token
# From: Running get_refresh_token.py script
refresh_token = "M.C5_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Tenant ID (usually "common" for multi-tenant apps)
tenant_id = "common"

# Example usage in code:
# import streamlit as st
# client_id = st.secrets["onedrive"]["client_id"]
# client_secret = st.secrets["onedrive"]["client_secret"]
# refresh_token = st.secrets["onedrive"]["refresh_token"]
